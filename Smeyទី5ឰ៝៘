-- [[ មុខងារស្គ្រីប JoJo របស់ហែង ]] --
local function StartJoJo()
    local ScreenGui = Instance.new("ScreenGui", game:GetService("CoreGui"))
    ScreenGui.Name = "JOJO_VISU_FREE"

    local MainBtn = Instance.new("TextButton", ScreenGui)
    MainBtn.Size = UDim2.new(0, 220, 0, 70)
    MainBtn.Position = UDim2.new(0.1, 0, 0.5, 0)
    MainBtn.BackgroundColor3 = Color3.fromRGB(30, 0, 50)
    MainBtn.Text = "⭐ JOJO: THE WORLD"
    MainBtn.TextColor3 = Color3.fromRGB(138, 43, 226)
    MainBtn.Font = Enum.Font.FredokaOne
    MainBtn.TextSize = 22
    MainBtn.Draggable = true

    local UIStroke = Instance.new("UIStroke", MainBtn)
    UIStroke.Thickness = 3
    UIStroke.Color = Color3.fromRGB(255, 255, 255)
    Instance.new("UICorner", MainBtn).CornerRadius = UDim.new(0, 15)

    local isRunning = false
    local frozenObjects = {}
    local char = player.Character or player.CharacterAdded:Wait()
    local root = char:WaitForChild("HumanoidRootPart")
    local lighting = game:GetService("Lighting")
    local colorCorrection = Instance.new("ColorCorrectionEffect", lighting)

    local function playSafeSound(id)
        local s = Instance.new("Sound", root)
        s.SoundId = "rbxassetid://"..id
        s.Volume = 5
        s:Play()
        game:GetService("Debris"):AddItem(s, 5)
    end

    local tsSphere = Instance.new("Part", root)
    tsSphere.Material = Enum.Material.ForceField
    tsSphere.Shape = Enum.PartType.Ball
    tsSphere.CanCollide = false
    tsSphere.CastShadow = false
    tsSphere.Size = Vector3.new(0,0,0)
    tsSphere.Color = Color3.fromRGB(138, 43, 226)
    local w = Instance.new("Weld", tsSphere)
    w.Part0 = tsSphere; w.Part1 = root

    local syncRemote = game:GetService("ReplicatedStorage"):WaitForChild("Syncing"):WaitForChild("Sync")

    MainBtn.MouseButton1Click:Connect(function()
        isRunning = not isRunning
        if isRunning then
            MainBtn.Text = "🌑 TOKI WO TOMARE!"
            MainBtn.BackgroundColor3 = Color3.fromRGB(75, 0, 130)
            pcall(function() playSafeSound("5679636294") end)
            colorCorrection.Enabled = true
            colorCorrection.Saturation = -1
            game:GetService("TweenService"):Create(tsSphere, TweenInfo.new(0.5), {Size = Vector3.new(150, 150, 150)}):Play()
            for _, obj in pairs(workspace:GetDescendants()) do
                if obj:IsA("Part") and not obj:IsDescendantOf(char) and not obj.Anchored then
                    obj.Anchored = true
                    table.insert(frozenObjects, obj)
                end
            end
        else
            MainBtn.Text = "⭐ JOJO: THE WORLD"
            MainBtn.BackgroundColor3 = Color3.fromRGB(30, 0, 50)
            pcall(function() playSafeSound("4329802996") end)
            colorCorrection.Enabled = false
            tsSphere.Size = Vector3.new(0,0,0)
            for _, obj in pairs(frozenObjects) do if obj then obj.Anchored = false end end
            frozenObjects = {}
        end
    end)

    task.spawn(function()
        while true do
            if isRunning then
                for _, p in pairs(game.Players:GetPlayers()) do
                    if p ~= player then
                        pcall(function() syncRemote:FireServer(p) end)
                    end
                end
            end
            task.wait(0.1)
        end
    end)
end

