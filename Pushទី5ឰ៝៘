-- មុខងារ Push
PushBtn.MouseButton1Click:Connect(function()
    local input = NameBox.Text:lower()
    local target = nil
    
    if #input < 3 then 
        PushBtn.Text = "NEED 3 LETTERS!"
        task.wait(1)
        PushBtn.Text = "EXECUTE PUSH"
        return 
    end

    for _, player in pairs(game:GetService("Players"):GetPlayers()) do
        if string.find(player.Name:lower(), input) or string.find(player.DisplayName:lower(), input) then
            target = player
            break
        end
    end

    if target and target.Character and target.Character:FindFirstChild("HumanoidRootPart") then
        local args = {
            [1] = target.Character.HumanoidRootPart,
            [2] = game.Players.LocalPlayer.Character.HumanoidRootPart.CFrame * CFrame.new(0, 0, -2)
        }
        
        local pushEvent = game:GetService("Players").LocalPlayer.Character:FindFirstChild("Push") and game:GetService("Players").LocalPlayer.Character.Push:FindFirstChild("PushEvent")
        
        if pushEvent then
            pushEvent:FireServer(unpack(args))
            PushBtn.Text = "PUSHED!"
            PushBtn.BackgroundColor3 = Color3.fromRGB(0, 255, 0)
        end
    else
        PushBtn.Text = "NOT FOUND!"
        PushBtn.BackgroundColor3 = Color3.fromRGB(255, 0, 0)
    end
    
    task.wait(1)
    PushBtn.Text = "EXECUTE PUSH"
    PushBtn.BackgroundColor3 = Color3.fromRGB(0, 255, 255)
end)
